package model

import (
	"database/sql"
	"time"
)

type {{.Name}} struct {
	ID        int64     `json:"id"`
	Title     string    `json:"title"`
	CreatedAt time.Time `json:"created_at"`
	UpdatedAt time.Time `json:"updated_at"`
}

// Migrate creates the {{.Name}} table if it doesn't exist.
func Migrate{{.Name}}(db *sql.DB) error {
	_, err := db.Exec(`
		CREATE TABLE IF NOT EXISTS {{.Table}} (
			id INTEGER PRIMARY KEY AUTOINCREMENT,
			title TEXT NOT NULL DEFAULT '',
			created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
			updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
		)
	`)
	return err
}

// Create inserts a new {{.Name}} record.
func Create{{.Name}}(db *sql.DB, r *{{.Name}}) error {
	r.CreatedAt = time.Now()
	r.UpdatedAt = time.Now()
	result, err := db.Exec(
		"INSERT INTO {{.Table}} (title, created_at, updated_at) VALUES (?, ?, ?)",
		r.Title, r.CreatedAt, r.UpdatedAt,
	)
	if err != nil {
		return err
	}
	r.ID, err = result.LastInsertId()
	return err
}

// Find{{.Name}} retrieves a {{.Name}} by ID.
func Find{{.Name}}(db *sql.DB, id int64) (*{{.Name}}, error) {
	r := &{{.Name}}{}
	err := db.QueryRow(
		"SELECT id, title, created_at, updated_at FROM {{.Table}} WHERE id = ?", id,
	).Scan(&r.ID, &r.Title, &r.CreatedAt, &r.UpdatedAt)
	if err != nil {
		return nil, err
	}
	return r, nil
}

// FindAll{{.Name}}s retrieves all {{.Name}} records.
func FindAll{{.Name}}s(db *sql.DB) ([]{{.Name}}, error) {
	rows, err := db.Query("SELECT id, title, created_at, updated_at FROM {{.Table}}")
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var records []{{.Name}}
	for rows.Next() {
		var r {{.Name}}
		if err := rows.Scan(&r.ID, &r.Title, &r.CreatedAt, &r.UpdatedAt); err != nil {
			return nil, err
		}
		records = append(records, r)
	}
	return records, rows.Err()
}

// Update{{.Name}} updates an existing {{.Name}} record.
func Update{{.Name}}(db *sql.DB, r *{{.Name}}) error {
	r.UpdatedAt = time.Now()
	_, err := db.Exec(
		"UPDATE {{.Table}} SET title = ?, updated_at = ? WHERE id = ?",
		r.Title, r.UpdatedAt, r.ID,
	)
	return err
}

// Delete{{.Name}} removes a {{.Name}} record by ID.
func Delete{{.Name}}(db *sql.DB, id int64) error {
	_, err := db.Exec("DELETE FROM {{.Table}} WHERE id = ?", id)
	return err
}
